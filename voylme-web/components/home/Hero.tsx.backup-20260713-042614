"use client";

import { useEffect, useState } from "react";

type HeroLocale = "en" | "ar";

const HERO_TEXT: Record<
  HeroLocale,
  {
    eyebrow: string;
    title: string;
    description: string;
    dir: "ltr" | "rtl";
  }
> = {
  en: {
    eyebrow: "FLIGHTS · HOTELS · CARS · ACTIVITIES",
    title: "Find the best travel deal faster.",
    description:
      "Search and compare trusted travel partners.",
    dir: "ltr",
  },
  ar: {
    eyebrow: "رحلات · فنادق · سيارات · أنشطة",
    title: "اعثر على أفضل عروض السفر بشكل أسرع.",
    description:
      "ابحث وقارن بين شركاء السفر الموثوقين.",
    dir: "rtl",
  },
};

function resolveHeroLocale(
  value: string | null,
): HeroLocale {
  const code = (value ?? "")
    .trim()
    .toLowerCase();

  if (
    code === "ar" ||
    code === "ara" ||
    code.startsWith("ara") ||
    code.includes("arabic")
  ) {
    return "ar";
  }

  return "en";
}

export default function Hero() {
  const [locale, setLocale] =
    useState<HeroLocale>("en");

  useEffect(() => {
    const syncLanguage = () => {
      setLocale(
        resolveHeroLocale(
          localStorage.getItem(
            "voylme-language",
          ),
        ),
      );
    };

    const handleLanguageChange = (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<string>;

      setLocale(
        resolveHeroLocale(
          customEvent.detail,
        ),
      );
    };

    syncLanguage();

    window.addEventListener(
      "voylme-language-change",
      handleLanguageChange,
    );

    window.addEventListener(
      "storage",
      syncLanguage,
    );

    window.addEventListener(
      "focus",
      syncLanguage,
    );

    return () => {
      window.removeEventListener(
        "voylme-language-change",
        handleLanguageChange,
      );

      window.removeEventListener(
        "storage",
        syncLanguage,
      );

      window.removeEventListener(
        "focus",
        syncLanguage,
      );
    };
  }, []);

  const content = HERO_TEXT[locale];

  return (
    <section className="home-hero">
      <div className="home-hero-frame voylme-final-overlay-hero">
        <img
          src="/images/hero-bg-clean.png"
          alt=""
          aria-hidden="true"
          draggable={false}
        />

        <div
          className="voylme-final-overlay-hero-copy"
          dir={content.dir}
          lang={locale}
        >
          <p className="voylme-final-overlay-hero-eyebrow">
            {content.eyebrow}
          </p>

          <h2>{content.title}</h2>

          <p className="voylme-final-overlay-hero-description">
            {content.description}
          </p>
        </div>
      </div>
    </section>
  );
}
